# syntax = docker/dockerfile:1.2
ARG DOCKER_REPO
ARG ORE_BUILD_VERSION
ARG DEBIAN_TAG
ARG CMAKE_BUILD_TYPE
FROM ${DOCKER_REPO}ore-build-dependencies:${ORE_BUILD_VERSION} as orebuild

LABEL Quaternion Risk Management
LABEL Description="Build ORE"

ARG NUM_CORES
ARG CMAKE_BUILD_TYPE

# Source archive is created in CI before_script (see ci/build_ore.yml)
# This replaces 15 individual COPY statements with a single ADD for faster buildah builds
ADD ore-source.tar.gz /ore/

# - add  -fpch-preprocess to CMAKE_CXX_FLAGS when QL_USE_PCH is set to ON
RUN cd /ore \
  && mkdir -p build.ore && cd build.ore \
  && cmake .. -GNinja -DCMAKE_CXX_COMPILER_LAUNCHER=sccache -DCMAKE_C_COMPILER_LAUNCHER=sccache -DCMAKE_CXX_COMPILER=/usr/bin/clang++ \
    -DCMAKE_EXE_LINKER_FLAGS="-fuse-ld=lld" -DCMAKE_SHARED_LINKER_FLAGS="-fuse-ld=lld" \
    -DORE_BUILD_SWIG=ON -DORE_PYTHON_INTEGRATION=ON -DQL_USE_PCH=OFF \
    -DORE_BUILD_DOC=ON -DCMAKE_BUILD_TYPE=${CMAKE_BUILD_TYPE} \
    -DCMAKE_CXX_FLAGS="-D BOOST_ENABLE_ASSERT_HANDLER $([ "$(uname -m)" = "x86_64" ] && echo "-mavx2")" \
    -DQL_ENABLE_SESSIONS=ON -DQL_ENABLE_PARALLEL_UNIT_TEST_RUNNER=ON -DQL_BUILD_EXAMPLES=OFF \
    -DQL_BUILD_BENCHMARK=OFF -DORE_ENABLE_PARALLEL_UNIT_TEST_RUNNER=ON -DORE_USE_ZLIB=ON \
    -DORE_ENABLE_OPENCL=ON -DORE_MULTITHREADING_CPU_AFFINITY=ON -DCMAKE_POLICY_DEFAULT_CMP0167=NEW

ARG SCCACHE_BUCKET
ARG SCCACHE_REGION
ARG SCCACHE_S3_USE_SSL
ARG SCCACHE_S3_KEY_PREFIX
ARG SCCACHE_IDLE_TIMEOUT

WORKDIR /ore/build.ore
RUN set -e; \
  [ -n "${SCCACHE_BUCKET}" ] && export SCCACHE_BUCKET; \
  [ -n "${SCCACHE_REGION}" ] && export SCCACHE_REGION; \
  [ -n "${SCCACHE_S3_USE_SSL}" ] && export SCCACHE_S3_USE_SSL; \
  [ -n "${SCCACHE_S3_KEY_PREFIX}" ] && export SCCACHE_S3_KEY_PREFIX; \
  [ -n "${SCCACHE_IDLE_TIMEOUT}" ] && export SCCACHE_IDLE_TIMEOUT; \
  sccache --start-server \
  || echo "WARNING: sccache server failed to start — caching may be unavailable"; \
  cmake --build . -- -j ${NUM_CORES} install; \
  BUILD_EXIT=$?; \
  sccache --show-stats || true; \
  if [ $BUILD_EXIT -ne 0 ]; then exit $BUILD_EXIT; fi

WORKDIR /
# Stage all artifacts and bundle into a single tar for faster cross-stage copy
# (single RUN avoids extra buildah layer checkpoints)
RUN mkdir -p html \
  && mkdir /html/ored && cp -r /ore/OREData/doc/html/* /html/ored \
  && mkdir /html/orea && cp -r /ore/OREAnalytics/doc/html/* /html/orea \
  && mkdir /html/qle && cp -r /ore/QuantExt/doc/html/* /html/qle \
  && mkdir /doxy_tagfiles \
  && cp /ore/QuantExt/doc/quantext.tag /doxy_tagfiles/quantext.tag \
  && cp /ore/OREData/doc/ored.tag /doxy_tagfiles/ored.tag \
  && cp /ore/OREAnalytics/doc/orea.tag /doxy_tagfiles/orea.tag \
  && mkdir -p oreswig/pythonlib \
  && mv /ore/build.ore/ORE-SWIG/ORE.py /oreswig/pythonlib \
  && mv /ore/build.ore/ORE-SWIG/_OREP.so /oreswig/pythonlib \
  && rm -rf ore \
  && mkdir -p /boostlibs \
  && find /usr/lib -maxdepth 2 -type f -name 'libboost*.so*' -exec cp {} /boostlibs/ \; \
  && mkdir -p /opencllibs \
  && find /usr/lib -maxdepth 2 -type f -name 'libOpenCL*' -exec cp {} /opencllibs/ \; \
  && tar cf /stage-output.tar \
      /usr/local/include \
      /usr/local/lib \
      /usr/local/bin \
      /boostlibs \
      /opencllibs \
      /usr/lib/llvm-19 \
      /usr/include/boost \
      /usr/include/CL \
      /oreswig \
      /doxy_tagfiles

FROM ${DOCKER_REPO}debian:${DEBIAN_TAG}

COPY --from=orebuild /stage-output.tar /stage-output.tar
RUN tar xf /stage-output.tar -C / && rm /stage-output.tar \
  && cp /boostlibs/* /usr/local/lib/ && rm -rf /boostlibs \
  && cp /opencllibs/* /usr/local/lib/ && rm -rf /opencllibs

RUN ldconfig
CMD bash
