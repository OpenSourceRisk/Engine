# syntax = docker/dockerfile:1.2
ARG DEBIAN_TAG
FROM ${DOCKER_TAG}debian:${DEBIAN_TAG}

ARG CCACHE_VERSION=4.13

RUN apt-get update \
  && DEBIAN_FRONTEND=noninteractive \
  apt-get install -y --no-install-recommends \
    build-essential \
    libbz2-dev \
    autoconf \
    libtool \
    cmake \
    ninja-build \
    zlib1g-dev \
    opencl-headers \
    ocl-icd-opencl-dev \
    libboost-all-dev \
    doxygen \
    graphviz \
    libeigen3-dev \
    clang \
    swig \
    lld \
    python3-dev \
    python3-pip \
    python3-venv \
    curl \
    libzstd-dev \
    podman \
    -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confold" \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/* \
  && mv /usr/bin/ld /usr/bin/ld.backup \
  && ln -s /usr/bin/lld /usr/bin/ld

# Install ccache from source (Trixie only provides 4.11.2)
RUN curl -sSL https://github.com/ccache/ccache/releases/download/v${CCACHE_VERSION}/ccache-${CCACHE_VERSION}.tar.gz \
    | tar -xz \
  && cd ccache-${CCACHE_VERSION} \
  && mkdir build && cd build \
  && cmake .. -GNinja -DCMAKE_BUILD_TYPE=Release -DREDIS_STORAGE_BACKEND=OFF \
  && ninja \
  && ninja install \
  && cd ../.. \
  && rm -rf ccache-${CCACHE_VERSION}

# Create ccache compiler symlinks in /usr/lib/ccache for compatibility with downstream Dockerfiles
RUN mkdir -p /usr/lib/ccache \
  && for cc in cc c++ gcc g++ clang clang++; do \
       ln -sf /usr/local/bin/ccache /usr/lib/ccache/$cc; \
     done

ARG SCCACHE_VERSION=v0.14.0
RUN set -eux \
  && case "$(dpkg --print-architecture)" in \
       amd64) ARCH=x86_64 ;; \
       arm64) ARCH=aarch64 ;; \
       *) echo "Unsupported architecture: $(dpkg --print-architecture)"; exit 1 ;; \
     esac \
  && SCCACHE_TARBALL="sccache-${SCCACHE_VERSION}-${ARCH}-unknown-linux-musl.tar.gz" \
  && SCCACHE_URL="https://github.com/mozilla/sccache/releases/download/${SCCACHE_VERSION}/${SCCACHE_TARBALL}" \
  && curl -fsSL "${SCCACHE_URL}" -o "/tmp/${SCCACHE_TARBALL}" \
  && curl -fsSL "${SCCACHE_URL}.sha256" -o "/tmp/${SCCACHE_TARBALL}.sha256" \
  && cd /tmp && echo "$(cat ${SCCACHE_TARBALL}.sha256)  ${SCCACHE_TARBALL}" | sha256sum -c - \
  && tar -xzf "/tmp/${SCCACHE_TARBALL}" -C /tmp \
  && mv "/tmp/sccache-${SCCACHE_VERSION}-${ARCH}-unknown-linux-musl/sccache" /usr/local/bin/sccache \
  && chmod +x /usr/local/bin/sccache \
  && rm -rf /tmp/sccache-*

RUN \
curl -sSL https://get.docker.com -o install-docker.sh && \
sh install-docker.sh --version 28

RUN python3 -m venv /venv
ENV PATH="/venv/bin:$PATH"

RUN \
pip3 install twine cibuildwheel==3.2.1 && \
rm -rf ~/.cache/pip

