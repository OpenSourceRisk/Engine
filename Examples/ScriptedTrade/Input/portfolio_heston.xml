  <Trade id="5:ScriptedAmericanEquityOptionMC">
    <TradeType>ScriptedTrade</TradeType>
    <Envelope>
      <CounterParty>CPTY</CounterParty>
      <NettingSetId>CPTY</NettingSetId>
      <AdditionalFields />
    </Envelope>
    <ScriptedTradeData>
      <!--<ScriptName>AmericanOption</ScriptName>-->
      <ProductTag>MC</ProductTag>
      <Script>
	<Code><![CDATA[
        NUMBER Payoff, d, ContinuationValue, currentNotional;
        Option = 0 * Underlying(ExerciseDates[SIZE(ExerciseDates)]);
        FOR d IN (SIZE(ExerciseDates), 1, -1) DO
          IF ExerciseDates[d] > TODAY THEN
            Payoff = PAY( PutCall * (Underlying(ExerciseDates[d]) - Strike), ExerciseDates[d], ExerciseDates[d], PayCcy);
            ContinuationValue = NPV( Option, ExerciseDates[d], Payoff > 0 );
            IF Payoff > 0 AND Payoff > ContinuationValue THEN
              Option = Payoff;
            END;
          END;
        END;
        Option = Option * Quantity * LongShort;
	currentNotional = Strike * Quantity;
	]]></Code>
	<NPV>Option</NPV>
	<Results>
          <Result>currentNotional</Result>
          <Result rename="notionalCurrency">PayCcy</Result>
	</Results>
	<CalibrationSpec>
          <Calibration>
            <Index>Underlying</Index>
            <Strikes>
              <Strike>Strike</Strike>
            </Strikes>
          </Calibration>
	</CalibrationSpec>
      </Script>
      <Data>
        <Event>
          <Name>ExerciseDates</Name>
          <ScheduleData>
            <Rules>
              <StartDate>20230605</StartDate>
              <EndDate>20230905</EndDate>
              <Tenor>1D</Tenor>
              <Calendar>TARGET</Calendar>
              <Convention>F</Convention>
              <TermConvention>F</TermConvention>
              <Rule>Forward</Rule>
              <EndOfMonth/>
              <FirstDate/>
              <LastDate/>
            </Rules>
          </ScheduleData>
        </Event>
        <Event>
          <Name>Expiry</Name>
          <Value>2023-09-05</Value>
        </Event>
        <Event>
          <Name>Settlement</Name>
          <Value>2023-09-05</Value>
        </Event>
        <Number>
          <Name>Strike</Name>
          <Value>4350</Value>
        </Number>
        <Number>
          <Name>PutCall</Name>
          <Value>1</Value>
        </Number>
        <Number>
          <Name>LongShort</Name>
          <Value>1</Value>
        </Number>
        <Number>
          <Name>Quantity</Name>
          <Value>1000</Value>
        </Number>
        <Currency>
          <Name>PayCcy</Name>
          <Value>EUR</Value>
        </Currency>
        <Index>
          <Name>Underlying</Name>
          <Value>EQ-RIC:.STOXX50E</Value>
        </Index>
      </Data>
    </ScriptedTradeData>
