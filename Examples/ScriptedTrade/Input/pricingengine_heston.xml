<?xml version="1.0"?>
<PricingEngines>
  
  <Product type="EquityOption">
    <Model>BlackScholesMerton</Model>
    <ModelParameters/>
    <Engine>AnalyticEuropeanEngine</Engine>
    <EngineParameters/>
  </Product>
    
  <Product type="EquityBarrierOption">
    <Model>BlackScholesMerton</Model>
    <ModelParameters />
    <Engine>AnalyticBarrierEngine</Engine>
    <EngineParameters />
  </Product>

  <Product type="EquityOptionAmerican">
    <Model>BlackScholesMerton</Model>
    <ModelParameters/>
    <Engine>FdBlackScholesVanillaEngine</Engine>
    <EngineParameters>
      <Parameter name="Scheme">Douglas</Parameter>
      <Parameter name="TimeGridPerYear">100</Parameter>
      <Parameter name="XGrid">100</Parameter>
      <Parameter name="DampingSteps">0</Parameter>
    </EngineParameters>
  </Product>

  <Product type="ScriptedTrade">
    <Model>Generic</Model>
    <ModelParameters>
      <!-- shared parameters -->
      <Parameter name="BaseCcy">EUR</Parameter>
      <Parameter name="EnforceBaseCcy">false</Parameter>
      <Parameter name="FullDynamicFx">true</Parameter>
      <Parameter name="GridCoarsening">3M(1W),1Y(1M),5Y(3M),10Y(1Y),50Y(5Y)</Parameter>
      <!--<Parameter name="Model">BlackScholes</Parameter>-->
      <Parameter name="Model">Heston</Parameter>
    </ModelParameters>
    <Engine>Generic</Engine>
    <EngineParameters>
      <Parameter name="Interactive">false</Parameter>
      <Parameter name="BootstrapTolerance">0.1</Parameter>
      <Parameter name="Engine">MC</Parameter>
      <Parameter name="Engine_MC">MC</Parameter>
      <Parameter name="Engine_FD">FD</Parameter>
      <Parameter name="Samples">10000</Parameter><!-- use 10k->10k for better match -->
      <Parameter name="SalvagingAlgorithm">None</Parameter>
      <Parameter name="SequenceType">SobolBrownianBridge</Parameter>
      <Parameter name="StateGridPoints">100</Parameter>
      <Parameter name="VarianceStateGridPoints">100</Parameter>
      <Parameter name="RegressionOrder">2</Parameter>
      <Parameter name="TimeStepsPerYear">24</Parameter><!-- use 24->100 steps for better match -->
      <!-- Heston specific -->
      <!-- ConstantBestFit, PiecewiseBootstrap, PiecewiseBestFit -->
      <Parameter name="Heston.CalibrationMethod">ConstantBestFit</Parameter>
      <Parameter name="CalibrationMoneyness">-2.0, -1.5, -1.0, -0.5, 0.0, 0.5, 1.0, 1.5, 2.0</Parameter>
      <Parameter name="Heston.CalibrationExpiries">3M</Parameter>
      <Parameter name="Heston.CalibrationVarianceTerms">1M, 2M, 3M, 6M, 9M, 1Y, 15M, 18M, 21M, 2Y, 5Y, 7Y, 10Y</Parameter>
      <!-- ordering: theta, kappa, sigma, rho, v0 -->
      <Parameter name="Heston.InitialValues">0.04, 2.0, 0.5, -0.7, 0.04</Parameter>
      <Parameter name="Heston.FixedValues">N,N,N,N,N</Parameter>               
      <Parameter name="Heston.RelaxedFellerConstraint">0.2</Parameter>
      <Parameter name="Heston.MaxCalibrationAttempts">0</Parameter>      
      <Parameter name="Heston.MaximumInitialValues">0.1, 20, 3, 0.9, 0.1</Parameter> 
      <Parameter name="Heston.EarlyExitThreshold">0.005</Parameter>            
      <Parameter name="Heston.MaxAcceptableError">0.05</Parameter>            
      <!-- PartialTruncation,
           FullTruncation,
           Reflection,
           NonCentralChiSquareVariance,
           QuadraticExponential,
           QuadraticExponentialMartingale,
           BroadieKayaExactSchemeLobatto,
           BroadieKayaExactSchemeLaguerre,
           BroadieKayaExactSchemeTrapezoidal -->
      <Parameter name="Heston.ProcessDiscretization">QuadraticExponential</Parameter>
      <Parameter name="Heston.Debug">true</Parameter>
    </EngineParameters>
  </Product>

</PricingEngines>
