<?xml version="1.0"?>
<PricingEngines>
  
  <Product type="Swap">
    <Model>DiscountedCashflows</Model>
    <ModelParameters/>
    <Engine>DiscountingSwapEngine</Engine>
    <EngineParameters/>
  </Product>

  <Product type="EquityOption">
    <Model>BlackScholesMerton</Model>
    <ModelParameters/>
    <Engine>AnalyticEuropeanEngine</Engine>
    <EngineParameters/>
  </Product>
    
  <Product type="EquityBarrierOption">
    <Model>BlackScholesMerton</Model>
    <ModelParameters />
    <Engine>AnalyticBarrierEngine</Engine>
    <EngineParameters />
  </Product>

  <Product type="EquityOptionAmerican">
    <Model>BlackScholesMerton</Model>
    <ModelParameters/>
    <Engine>FdBlackScholesVanillaEngine</Engine>
    <EngineParameters>
      <Parameter name="Scheme">Douglas</Parameter>
      <Parameter name="TimeGridPerYear">100</Parameter>
      <Parameter name="XGrid">100</Parameter>
      <Parameter name="DampingSteps">0</Parameter>
    </EngineParameters>
  </Product>

  <Product type="ScriptedTrade">
    <Model>Generic</Model>
    <ModelParameters>
      <!-- shared parameters -->
      <Parameter name="BaseCcy">EUR</Parameter>
      <Parameter name="EnforceBaseCcy">false</Parameter>
      <Parameter name="FullDynamicFx">true</Parameter>
      <Parameter name="GridCoarsening">3M(1W),1Y(1M),5Y(3M),10Y(1Y),50Y(5Y)</Parameter>
      <!--<Parameter name="Model">BlackScholes</Parameter>-->
      <Parameter name="Model">Heston</Parameter>
      <!-- model selection -->
      <!--<Parameter name="Model_SingleAssetOption(EQ)">BlackScholes</Parameter>-->
      <Parameter name="Model_SingleAssetOption(EQ)">Heston</Parameter>
    </ModelParameters>
    <Engine>Generic</Engine>
    <EngineParameters>
      <!-- shared parameters -->
      <Parameter name="Interactive">false</Parameter>
      <Parameter name="BootstrapTolerance">0.1</Parameter>
      <!-- default parameters-->
      <Parameter name="Engine">MC</Parameter>
      <Parameter name="Samples">10000</Parameter>
      <Parameter name="SalvagingAlgorithm">None</Parameter>
      <Parameter name="SequenceType">SobolBrownianBridge</Parameter>
      <Parameter name="StateGridPoints">24</Parameter>
      <Parameter name="RegressionOrder">2</Parameter>
      <Parameter name="TimeStepsPerYear">48</Parameter>
      <!-- asset class specific choices -->
      <Parameter name="Engine_SingleAssetOption(EQ)">MC</Parameter>
      <Parameter name="Engine_SingleAssetOptionBwd(EQ)">FD</Parameter>
      <Parameter name="Engine_SingleAssetOptionBwd(FX)">FD</Parameter>
      <Parameter name="Engine_SingleAssetOptionBwd(COMM)">FD</Parameter>
      
      <!-- Heston specific -->

      <Parameter name="CalibrationMoneyness">-2.0, -1.5, -1.0, -0.5, 0.0, 0.5, 1.0, 1.5, 2.0</Parameter>
      <Parameter name="HestonCalibrationExpiries">3M</Parameter>
      <Parameter name="HestonCalibrationVarianceTerms">1M, 2M, 3M, 6M, 9M, 1Y, 15M, 18M, 21M, 2Y, 5Y, 7Y, 10Y</Parameter>
      <!-- ordering: theta, kappa, sigma, rho, v0 -->
      <!--<Parameter name="HestonInitialValues">0.04, 1.0, 0.000001, -0.5, 0.04</Parameter>-->
      <Parameter name="HestonInitialValues">0.04, 2.0, 0.5, -0.7, 0.04</Parameter>
      <!--<Parameter name="HestonFixedValues">Y,Y,Y,Y,Y</Parameter>-->           
      <Parameter name="HestonFixedValues">N,N,N,N,N</Parameter>               
      <Parameter name="HestonRelaxedFellerConstraint">0.2</Parameter>
      <Parameter name="HestonMaxCalibrationAttempts">0</Parameter>      
      <Parameter name="HestonMaximumInitialValues">0.1, 20, 3, 0.9, 0.1</Parameter> 
      <Parameter name="HestonEarlyExitThreshold">0.005</Parameter>            
      <Parameter name="HestonMaxAcceptableError">0.05</Parameter>            
      <!-- PartialTruncation,
           FullTruncation,
           Reflection,
           NonCentralChiSquareVariance,
           QuadraticExponential,
           QuadraticExponentialMartingale,
           BroadieKayaExactSchemeLobatto,
           BroadieKayaExactSchemeLaguerre,
           BroadieKayaExactSchemeTrapezoidal -->
      <!--<Parameter name="HestonProcessDiscretization">QuadraticExponentialMartingale</Parameter>-->
      <Parameter name="HestonProcessDiscretization">QuadraticExponential</Parameter>
      <Parameter name="Debug">true</Parameter>
    </EngineParameters>
  </Product>

</PricingEngines>
