<ORE>
  <Setup>
    <Parameter name="asofDate">20160205</Parameter>
    <Parameter name="inputPath">./Input/Inflation</Parameter>
    <Parameter name="outputPath">./Output/Inflation</Parameter>
    <Parameter name="logFile">log.txt</Parameter>
    <Parameter name="logMask">255</Parameter>
    <Parameter name="marketDataFile">market_20160205_slim.txt</Parameter>
    <Parameter name="fixingDataFile">fixings_20160205_slim.txt</Parameter>
    <Parameter name="implyTodaysFixings">Y</Parameter>
    <Parameter name="curveConfigFile">curveconfig.xml</Parameter>
    <Parameter name="conventionsFile">conventions.xml</Parameter>
    <Parameter name="marketConfigFile">todaysmarket.xml</Parameter>
    <Parameter name="pricingEnginesFile">pricingengine.xml</Parameter>
    <Parameter name="portfolioFile">portfolio_cappedfloored_zciis.xml</Parameter>
    <Parameter name="scriptLibrary">scriptlibrary.xml</Parameter>
    <Parameter name="observationModel">None</Parameter>
    <Parameter name="continueOnError">true</Parameter>
    <Parameter name="lazyMarketBuilding">true</Parameter>
    <Parameter name="nThreads">1</Parameter>
  </Setup>
  <Analytics>
    <Analytic type="npv">
      <Parameter name="active">Y</Parameter>
      <Parameter name="baseCurrency">EUR</Parameter>
      <Parameter name="outputFileName">npv.csv</Parameter>
      <Parameter name="additionalResults">Y</Parameter>
      <Parameter name="additionalResultsReportPrecision">9</Parameter>
    </Analytic>
    <Analytic type="cashflow">
      <Parameter name="active">Y</Parameter>
      <Parameter name="outputFileName">flows.csv</Parameter>
      <Parameter name="includePastCashflows">Y</Parameter>
    </Analytic>
    <Analytic type="curves">
      <Parameter name="active">Y</Parameter>
      <Parameter name="grid">360,1M</Parameter>
      <Parameter name="outputFileName">curves.csv</Parameter>
      <Parameter name="outputTodaysMarketCalibration">true</Parameter>
    </Analytic>
    <Analytic type="sensitivity">
      <Parameter name="active">N</Parameter>
      <Parameter name="laxFxConversion">Y</Parameter>
      <Parameter name="marketConfigFile">simulation.xml</Parameter>
      <Parameter name="sensitivityConfigFile">sensitivity.xml</Parameter>
      <Parameter name="pricingEnginesFile">pricingengine.xml</Parameter>
      <Parameter name="scenarioOutputFile">scenario.csv</Parameter>
      <Parameter name="sensitivityOutputFile">sensitivity.csv</Parameter>
      <Parameter name="crossGammaOutputFile">crossgamma.csv</Parameter>
      <Parameter name="recalibrateModels">N</Parameter>
      <Parameter name="outputSensitivityThreshold">0.000001</Parameter>
      <Parameter name="parSensitivity">N</Parameter>
      <Parameter name="parSensitivityOutputFile">parsensitivity.csv</Parameter>
      <Parameter name="outputJacobi">N</Parameter>
      <Parameter name="jacobiOutputFile">jacobi.csv</Parameter>
      <Parameter name="jacobiInverseOutputFile">jacobi_inverse.csv</Parameter>
    </Analytic>
  </Analytics>
</ORE>
