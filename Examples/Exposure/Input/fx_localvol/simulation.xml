<?xml version="1.0"?>
<Simulation>
    <Parameters>
      <Grid>70,1M</Grid>
      <Calendar>EUR,USD</Calendar>
      <Sequence>SobolBrownianBridge</Sequence>
      <Scenario>Simple</Scenario>
      <Seed>42</Seed>
      <Samples>10000</Samples>
      <Ordering>Steps</Ordering>
      <DirectionIntegers>JoeKuoD7</DirectionIntegers>
    </Parameters>
  <CrossAssetModel>
    <Discretization>BestMarginalDiscretization</Discretization>
    <DomesticCcy>USD</DomesticCcy>
    <Currencies>
      <Currency>USD</Currency>
      <Currency>EUR</Currency>
    </Currencies>
    <BootstrapTolerance>0.0001</BootstrapTolerance>
    <InterestRateModels>

      <!-- calibrate stochastic vol interest rate processes -->

      <!-- <LGM ccy="default"> -->
      <!--   <CalibrationType>Bootstrap</CalibrationType> -->
      <!--   <Volatility> -->
